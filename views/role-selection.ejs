<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TicketBooking - Chọn vai trò</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <div class="role-selection">
            <div class="header">
                <h1>🎫 TicketBooking</h1>
                <p>Hệ thống quản lý đặt vé tàu</p>
            </div>

            <div class="role-cards">
                <a href="/login?role=passenger" class="role-card clickable">
                    <div class="role-icon">👤</div>
                    <h2>Hành khách</h2>
                    <p>Đặt vé tàu, xem lịch sử vé</p>
                </a>

                <a href="/login?role=staff_hq" class="role-card clickable">
                    <div class="role-icon">🏢</div>
                    <h2>Quản lý chi nhánh</h2>
                    <p>Quản lý toàn bộ hệ thống</p>
                </a>
            </div>
        </div>
    </div>
</body>
</html>
