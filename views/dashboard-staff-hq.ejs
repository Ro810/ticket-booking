<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Quản lý trụ sở - TicketBooking</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body data-manager-id="<%= user.id %>">
    <div class="navbar">
        <div style="display:flex;align-items:center;gap:10px">
            <button class="sidebar-toggle" onclick="toggleSidebar()">☰</button>
            <div class="navbar-brand">🎫 TicketBooking - Quản lý trụ sở</div>
        </div>
        <div class="navbar-right">
            <span><%= user.fullname %></span>
            <a href="/logout" class="btn-logout">Đăng xuất</a>
        </div>
    </div>
    <div class="mobile-overlay" onclick="toggleSidebar()"></div>
    <div class="container dashboard">
        <div class="sidebar" id="sidebar">
            <ul class="menu">
                <li class="active"><a href="#overview" onclick="return navTo('#overview')">📊 Tổng quan</a></li>
                <li><a href="#branches" onclick="return navTo('#branches')">🏢 Chi nhánh</a></li>
                <li><a href="#employees" onclick="return navTo('#employees')">👨‍💼 Nhân viên</a></li>
                <li><a href="#users" onclick="return navTo('#users')">👥 Khách hàng</a></li>
                <li><a href="#trainEntities" onclick="return navTo('#trainEntities')">🚆 Tàu</a></li>
                <li><a href="#trains" onclick="return navTo('#trains')">🚂 Chuyến tàu</a></li>
                <li><a href="#stations" onclick="return navTo('#stations')">🚉 Ga tàu</a></li>
                <li><a href="#tickets" onclick="return navTo('#tickets')">🎫 Vé</a></li>
                <li><a href="#reports" onclick="return navTo('#reports')">📈 Báo cáo</a></li>
            </ul>
        </div>
        <div class="content">
            <!-- Overview -->
            <section id="overview" class="section active">
                <h2>Tổng quan hệ thống</h2>
                <div class="stats-grid">
                    <div class="stat-card-mini"><div class="stat-icon" style="background:#e8f5e9;color:#28a745">💰</div><div class="stat-info"><h4>Tổng doanh thu</h4><div class="stat-value"><%= (stats.totalRevenue || 0).toLocaleString('vi-VN') %>đ</div></div></div>
                    <div class="stat-card-mini"><div class="stat-icon" style="background:#e3f2fd;color:#667eea">🎫</div><div class="stat-info"><h4>Tổng vé bán</h4><div class="stat-value"><%= stats.totalTickets || 0 %></div></div></div>
                    <div class="stat-card-mini"><div class="stat-icon" style="background:#f3e5f5;color:#764ba2">👤</div><div class="stat-info"><h4>Khách hàng</h4><div class="stat-value"><%= stats.totalCustomers || 0 %></div></div></div>
                </div>
                <h2 style="margin-top:30px">Thông tin cá nhân</h2>
                <div class="info-card">
                    <p><strong>Họ tên:</strong> <%= user.fullname %></p>
                    <p><strong>SĐT:</strong> <%= user.phone %></p>
                    <p><strong>Mã NV:</strong> <%= user.id %></p>
                    <p><strong>Lương:</strong> <%= (user.salary || 0).toLocaleString('vi-VN') %> VNĐ</p>
                    <p><strong>Chi nhánh:</strong> <%= user.branchName || user.idBranch %></p>
                    <p><strong>Chức vụ:</strong> <%= user.employeeRole %></p>
                </div>
            </section>

            <!-- Branches -->
            <section id="branches" class="section">
                <h2>Quản lý chi nhánh</h2>
                <div class="search-box"><input type="text" id="branchSearch" placeholder="🔍 Tìm chi nhánh..." oninput="searchTable('branchesTableBody','branchSearch')"><button class="btn btn-success" onclick="openBranchModal()">+ Thêm chi nhánh</button></div>
                <table class="table"><thead><tr><th>Mã</th><th>Địa chỉ</th><th>SĐT</th><th>Hành động</th></tr></thead>
                <tbody id="branchesTableBody">
                <% branches.forEach(b => { %>
                <tr data-search="<%= b.id %> <%= b.name %>"><td><%= b.id %></td><td><%= b.name %></td><td><%= b.phoneNumber || '-' %></td><td><div class="row-actions"><button class="btn-small" onclick="editBranch('<%= b.id %>','<%= (b.name||'').replace(/'/g,"\\'") %>','<%= b.phoneNumber||'' %>')">Sửa</button><button class="btn-small btn-danger" onclick="deleteBranch('<%= b.id %>')">Xóa</button></div></td></tr>
                <% }); %>
                </tbody></table>
            </section>

            <!-- Employees -->
            <section id="employees" class="section">
                <h2>Quản lý nhân viên</h2>
                <div class="search-box"><input type="text" id="empSearch" placeholder="🔍 Tìm nhân viên..." oninput="searchTable('empTableBody','empSearch')"><button class="btn btn-success" onclick="openEmployeeModal()">+ Thêm nhân viên</button></div>
                <table class="table"><thead><tr><th>Mã NV</th><th>Họ tên</th><th>Chức vụ</th><th>SĐT</th><th>Chi nhánh</th><th>Lương</th><th>Hành động</th></tr></thead>
                <tbody id="empTableBody">
                <% employees.forEach(e => { %>
                <tr data-search="<%= e.id %> <%= e.fullname %> <%= e.role %>"><td><%= e.id %></td><td><%= e.fullname %></td><td><%= e.role %></td><td><%= e.phoneNumber %></td><td><%= e.branchName || e.idBranch %></td><td><%= (e.salary||0).toLocaleString('vi-VN') %></td><td><div class="row-actions"><button class="btn-small" onclick="editEmployee('<%= e.id %>','<%= (e.fullname||'').replace(/'/g,"\\'") %>','<%= e.salary %>','<%= e.role %>','<%= e.phoneNumber %>','<%= e.idBranch %>')">Sửa</button><button class="btn-small btn-danger" onclick="deleteEmployee('<%= e.id %>')">Xóa</button></div></td></tr>
                <% }); %>
                </tbody></table>
            </section>

            <!-- Customers -->
            <section id="users" class="section">
                <h2>Quản lý khách hàng</h2>
                <div class="search-box"><input type="text" id="customerSearch" placeholder="🔍 Tìm khách hàng..." oninput="searchCustomersTable()"><button class="btn btn-success" onclick="openCustomerModal()">+ Thêm khách hàng</button></div>
                <table class="table" id="customersTable"><thead><tr><th>Mã KH</th><th>Tên</th><th>SĐT</th><th>Địa chỉ</th><th>Hành động</th></tr></thead>
                <tbody id="customersTableBody">
                <% customers.forEach(c => { %>
                <tr data-cid="<%= c.id %>" data-name="<%= c.Name %>" data-phone="<%= c.phoneNumber %>"><td><%= c.id %></td><td><%= c.Name %></td><td><%= c.phoneNumber %></td><td><%= c.Address || '-' %></td><td><div class="row-actions"><button class="btn-small" style="background:#17a2b8;color:#fff" onclick="viewCustomerDetail('<%= c.id %>')">Chi tiết</button><button class="btn-small" onclick="editCustomerRow('<%= c.id %>','<%= c.Name %>','<%= c.phoneNumber %>','<%= c.Address %>')">Sửa</button><button class="btn-small btn-danger" onclick="deleteCustomerRow('<%= c.id %>')">Xóa</button></div></td></tr>
                <% }); %>
                </tbody></table>
            </section>

            <!-- Train Entities -->
            <section id="trainEntities" class="section">
                <h2>Quản lý tàu</h2>
                <div class="search-box"><input type="text" id="trainEntitySearch" placeholder="🔍 Tìm tàu..." oninput="searchTable('trainEntityTableBody','trainEntitySearch')"><button class="btn btn-success" onclick="openTrainEntityModal()">+ Thêm tàu</button></div>
                <table class="table"><thead><tr><th>Mã tàu</th><th>Hãng SX</th><th>Ghế hạng 1</th><th>Ghế hạng 2</th><th>Chi nhánh</th><th>Hành động</th></tr></thead>
                <tbody id="trainEntityTableBody">
                <% trainEntities.forEach(t => { %>
                <tr data-search="<%= t.id %> <%= t.ManufacturingBrand %>"><td><%= t.id %></td><td><%= t.ManufacturingBrand %></td><td><%= t.class1Seats %></td><td><%= t.class2Seats %></td><td><%= t.branchName || t.idBranch %></td><td><div class="row-actions"><button class="btn-small" onclick="editTrainEntity('<%= t.id %>','<%= (t.ManufacturingBrand||'').replace(/'/g,"\\'") %>','<%= t.idBranch %>')">Sửa</button><button class="btn-small btn-danger" onclick="deleteTrainEntity('<%= t.id %>')">Xóa</button></div></td></tr>
                <% }); %>
                </tbody></table>
            </section>

            <!-- Train Rides -->
            <section id="trains" class="section">
                <h2>Quản lý chuyến tàu</h2>
                <div class="search-box"><input type="text" id="trainSearch" placeholder="🔍 Tìm theo tuyến..." oninput="searchTrainsTable()"><button class="btn btn-success" onclick="openTrainModal()">+ Thêm chuyến tàu</button></div>
                <table class="table" id="trainsTable"><thead><tr><th>Mã chuyến</th><th>Tuyến</th><th>Khởi hành</th><th>Tàu</th><th>Giá vé</th><th>Hành động</th></tr></thead>
                <tbody id="trainsTableBody">
                <% trainRides.forEach(tr => { %>
                <tr data-train-id="<%= tr.id %>" data-route="<%= tr.DepartureStation %> → <%= tr.Destination %>"><td><%= tr.id %></td><td><%= tr.DepartureStation %> → <%= tr.Destination %></td><td><%= new Date(tr.DepartureTime).toLocaleString('vi-VN') %></td><td><%= tr.idTrain || '-' %></td><td><%= (tr.price||0).toLocaleString('vi-VN') %>đ</td><td><div class="row-actions"><button class="btn-small" style="background:#17a2b8;color:#fff" onclick="viewTrainDetail('<%= tr.id %>')">Chi tiết</button><button class="btn-small" onclick="editTrainRow('<%= tr.id %>','<%= tr.DepartureStation %>','<%= tr.Destination %>','<%= tr.DepartureTime %>','<%= tr.idTrain %>','<%= tr.price||0 %>')">Sửa</button><button class="btn-small btn-danger" onclick="deleteTrainRow('<%= tr.id %>')">Xóa</button></div></td></tr>
                <% }); %>
                </tbody></table>
            </section>

            <!-- Stations -->
            <section id="stations" class="section">
                <h2>Quản lý ga tàu</h2>
                <div class="search-box"><input type="text" id="stationSearch" placeholder="🔍 Tìm ga..." oninput="searchStationsTable()"><button class="btn btn-success" onclick="openStationModal()">+ Thêm ga tàu</button></div>
                <table class="table"><thead><tr><th>Tên ga</th><th>Địa chỉ</th><th>Hành động</th></tr></thead>
                <tbody id="stationsTableBody">
                <% if (locals.stations && stations.length > 0) { %><% stations.forEach(st => { %>
                <tr data-name="<%= st.Name %>" data-search="<%= st.Name %> <%= st.Address || '' %>"><td><%= st.Name %></td><td><%= st.Address || '-' %></td><td><div class="row-actions"><button class="btn-small" onclick="editStationRow('<%= st.Name %>','<%= st.Address || '' %>')">Sửa</button><button class="btn-small btn-danger" onclick="deleteStationRow('<%= st.Name %>')">Xóa</button></div></td></tr>
                <% }); %><% } %>
                </tbody></table>
            </section>

            <!-- Tickets -->
            <section id="tickets" class="section">
                <h2>Vé toàn hệ thống</h2>
                <div class="search-box" style="gap:10px;flex-wrap:wrap">
                    <input type="text" id="ticketSearch" placeholder="🔍 Tìm theo mã vé..." oninput="searchTicketsTable()">
                    <select id="ticketBranchFilter" onchange="applyBranchFilter('tickets')">
                        <option value="all" <%= branchFilter === 'all' ? 'selected' : '' %>>Toàn hệ thống</option>
                        <% branches.forEach(b => { %><option value="<%= b.id %>" <%= branchFilter === b.id ? 'selected' : '' %>><%= b.name %></option><% }); %>
                    </select>
                    <button class="btn btn-primary" onclick="applyBranchFilter('tickets')">Lọc</button>
                </div>
                <table class="table"><thead><tr><th>Mã vé</th><th>Khách hàng</th><th>Chuyến</th><th>Ghế</th><th>Giá</th><th>Chi nhánh</th><th>Trạng thái</th><th>Hành động</th></tr></thead>
                <tbody id="ticketsTableBody">
                <% tickets.forEach(t => { %><% const isFuture = new Date(t.DepartureTime) > new Date(); const tStatus = t.status || 'paid'; %>
                <tr data-search="<%= t.id %> <%= t.customerName || '' %>"><td><%= t.id %></td><td><%= t.customerName || t.idCustomer %></td><td><%= t.DepartureStation %> → <%= t.Destination %></td><td><%= t.SeatClass || '-' %> <%= t.SeatNumber ? '(' + t.SeatNumber + ')' : '' %></td><td><%= (t.price||0).toLocaleString('vi-VN') %>đ</td><td><%= t.branchName || '-' %></td>
                <td><% if (tStatus==='cancelled') { %><span class="badge badge-danger">Đã hủy</span><% } else if (tStatus==='pending') { %><span class="badge badge-warning">Chờ TT</span><% } else if (isFuture) { %><span class="badge badge-info">Sắp KH</span><% } else { %><span class="badge badge-success">Hoàn thành</span><% } %></td>
                <td><% if (tStatus !== 'cancelled') { %><div class="row-actions"><% if (tStatus==='pending') { %><button class="btn-small btn-success" onclick="updateTicketStatus('<%= t.id %>','paid')">Xác nhận</button><% } %><button class="btn-small btn-danger" onclick="cancelTicketRow('<%= t.id %>')">Hủy</button></div><% } else { %>-<% } %></td></tr>
                <% }); %>
                </tbody></table>
            </section>

            <!-- Reports -->
            <section id="reports" class="section">
                <h2>Báo cáo thống kê</h2>
                <div class="search-box" style="gap:10px;flex-wrap:wrap;margin-bottom:20px">
                    <select id="reportBranchFilter" onchange="applyBranchFilter('reports')">
                        <option value="all" <%= branchFilter === 'all' ? 'selected' : '' %>>Toàn hệ thống</option>
                        <% branches.forEach(b => { %><option value="<%= b.id %>" <%= branchFilter === b.id ? 'selected' : '' %>><%= b.name %></option><% }); %>
                    </select>
                    <button class="btn btn-primary" onclick="applyBranchFilter('reports')">Lọc</button>
                </div>
                <div class="stats-grid">
                    <div class="stat-card-mini"><div class="stat-icon" style="background:#e8f5e9;color:#28a745">💰</div><div class="stat-info"><h4>Tổng doanh thu</h4><div class="stat-value"><%= (stats.totalRevenue||0).toLocaleString('vi-VN') %>đ</div></div></div>
                    <div class="stat-card-mini"><div class="stat-icon" style="background:#e3f2fd;color:#667eea">🎫</div><div class="stat-info"><h4>Tổng vé</h4><div class="stat-value"><%= stats.totalTickets||0 %></div></div></div>
                </div>
                <h3 style="margin-top:25px">Doanh số theo chi nhánh</h3>
                <table class="table"><thead><tr><th>Chi nhánh</th><th>Số vé</th><th>Doanh thu</th></tr></thead><tbody>
                <% branchStats.forEach(b => { %><tr><td><%= b.branchName||'Chưa xác định' %></td><td><%= b.ticketCount||0 %></td><td><%= (b.revenue||0).toLocaleString('vi-VN') %>đ</td></tr><% }); %>
                </tbody></table>
                <div class="stats-grid" style="margin-top:25px">
                    <div class="stat-card-mini" style="flex-direction:column;align-items:stretch"><h4 style="margin-bottom:10px">Vé theo chi nhánh</h4><canvas id="chartBranch"></canvas></div>
                    <div class="stat-card-mini" style="flex-direction:column;align-items:stretch"><h4 style="margin-bottom:10px">Vé theo loại ghế</h4><canvas id="chartSeat"></canvas></div>
                </div>
                <div class="stat-card-mini" style="flex-direction:column;align-items:stretch;margin-top:20px"><h4 style="margin-bottom:10px">Doanh thu theo tháng</h4><canvas id="chartMonth"></canvas></div>
            </section>
        </div>
    </div>

    <%- include('partials/modals-hq') %>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script> window.allCustomers = <%- JSON.stringify(customers || []) %>; </script>
    <script> window.allBranches = <%- JSON.stringify(branches || []) %>; </script>
    <script> window.allTrainEntities = <%- JSON.stringify(trainEntities || []) %>; </script>
    <script src="/js/ui-utils.js"></script>
    <script src="/js/manager-dashboard.js"></script>
    <script src="/js/station-management.js"></script>
    <script>
      const chartData = <%- JSON.stringify(locals.chartData || {}) %>;
      const branchStats = <%- JSON.stringify(locals.branchStats || []) %>;
      if (branchStats.length) { new Chart(document.getElementById('chartBranch'), { type:'bar', data:{ labels:branchStats.map(d=>d.branchName||'Khác'), datasets:[{label:'Số vé',data:branchStats.map(d=>d.ticketCount),backgroundColor:['#667eea','#764ba2','#28a745']}] }, options:{responsive:true,plugins:{legend:{display:false}}} }); }
      if (chartData.bySeat&&chartData.bySeat.length) { new Chart(document.getElementById('chartSeat'), { type:'doughnut', data:{ labels:chartData.bySeat.map(d=>d.SeatType), datasets:[{data:chartData.bySeat.map(d=>d.cnt),backgroundColor:['#667eea','#764ba2']}] }, options:{responsive:true} }); }
      if (chartData.byMonth&&chartData.byMonth.length) { new Chart(document.getElementById('chartMonth'), { type:'line', data:{ labels:chartData.byMonth.map(d=>d.month), datasets:[{label:'Số vé',data:chartData.byMonth.map(d=>d.cnt),borderColor:'#667eea',fill:false,tension:0.3}] }, options:{responsive:true} }); }
    </script>
</body>
</html>